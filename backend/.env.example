# Standing backend env. Copy to backend/.env and fill in real keys for the
# live path. A clean checkout works fully offline with the defaults below —
# DEMO_MODE=1 means every external client (Qwen/Exa/Firecrawl) returns canned
# fixtures from backend/fixtures/ instead of making network calls.

QWEN_API_KEY=...
QWEN_BASE_URL=https://ws-9rrxlxrfszsh2uqb.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
EXA_API_KEY=...
FIRECRAWL_API_KEY=...
DEMO_MODE=0
